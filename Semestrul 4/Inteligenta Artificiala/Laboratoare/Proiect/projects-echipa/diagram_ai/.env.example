# Copiați acest fișier în .env și completați valorile
# Windows:  copy .env.example .env
# Linux:    cp .env.example .env

# ============================================================
# === Azure OpenAI (Azure for Students) ===
# ============================================================

# Cheia API — din Azure Portal > resursa OpenAI > Keys and Endpoint
AZURE_OPENAI_API_KEY=<your_azure_openai_api_key_here>

# Endpoint — din Azure Portal > resursa OpenAI > Keys and Endpoint
# Format: https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://gabones.services.ai.azure.com/

# Numele deployment-ului creat în Azure AI Studio (nu modelul, ci deployment-ul!)
# Exemple comune: gpt-4o, gpt-4o-mini, gpt-35-turbo
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Versiunea API Azure OpenAI
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ============================================================
# === GitHub Integration (opțional) ===
# ============================================================
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=owner/repo-name

# ============================================================
# === Paths ===
# ============================================================
DATA_DIR=./data
CHROMA_DB_PATH=./data/chromadb
MODELS_DIR=./models

# ============================================================
# === Agent config ===
# ============================================================
MAX_RETRIES=3
RAG_TOP_K=5
TEMPERATURE=0.2
