<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="300.0" prefHeight="200.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controller.LoginController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    <Label text="Joc Online - Autentificare"
           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
    <TextField fx:id="aliasField" promptText="Alias"/>
    <Button text="Login" onAction="#handleLogin" prefWidth="120.0"/>
</VBox>
