     1                                  %ifndef _FACTORIAL_ASM_ ; continuăm dacă _FACTORIAL_ASM_ este nedefinit
     2                                  %define _FACTORIAL_ASM_ ; și ne asigurăm că devine definit
     3                                                          ; astfel, %include permite doar o singură includere
     4                                  
     5                                  ;definire procedura
     6                                  factorial: ; int _stdcall factorial(int n)
     7 00000000 66B801000000            	mov eax, 1
     8 00000006 66678B4C2404            	mov ecx, [esp + 4]
     9                                  	
    10                                  	repet: 
    11 0000000C 66F7E1                  		mul ecx
    12 0000000F E2FB                    	loop repet ; atentie, cazul ecx = 0 nu e tratat!
    13                                  
    14 00000011 C20400                  	ret 4 ; in acest caz 4 reprezinta numarul de octeti ce trebuie eliberati de pe stiva (parametrul pasat procedurii)
    15                                  
    16                                  %endif  
