     1                                  bits 32 ; assembling for the 32 bits architecture
     2                                  
     3                                  ; declare the EntryPoint (a label defining the very first instruction of the program)
     4                                  global start        
     5                                  
     6                                  ; declare external functions needed by our program
     7                                  extern exit               ; tell nasm that exit exists even if we won't be defining it
     8                                  import exit msvcrt.dll    ; exit is a function that ends the calling process. It is defined in msvcrt.dll
     9                                                            ; msvcrt.dll contains exit, printf and all the other important C-runtime specific functions
    10                                  
    11                                  ; our data is declared here (the variables needed by our program)
    12                                  segment data use32 class=data
    13 00000000 64000000                    n dd 100
    14 00000004 00000000                    s dd 0
    15                                  ; our code starts here
    16                                  segment code use32 class=code
    17                                      start:
    18                                          ;i=1
    19                                          ;s=0
    20                                          ;while(i<=n)
    21                                          ;{
    22                                          ;       s=s+i
    23                                          ;        i++
    24                                          ;}
    25                                          ;
    26                                          
    27 00000000 B901000000                      mov ecx,1  ;ecx=i=1
    28 00000005 31C0                            xor eax,eax   ;eax=s=0
    29                                      .start_loop:
    30 00000007 3B0D[00000000]                  cmp ecx,[n] ;(Comparam i cu n)
    31 0000000D 7F05                            jg .end_loop ;Daca i>n oprim bucla while
    32 0000000F 01C8                            add eax,ecx ;s=s+i
    33 00000011 41                              inc ecx  ;i++
    34 00000012 EBF3                            jmp .start_loop
    35                                      .end_loop:
    36 00000014 A3[04000000]                    mov [s],eax
    37                                          ; exit(0)
    38 00000019 6A00                            push    dword 0      ; push the parameter for exit onto the stack
    39 0000001B FF15[00000000]                  call    [exit]       ; call exit to terminate the program
