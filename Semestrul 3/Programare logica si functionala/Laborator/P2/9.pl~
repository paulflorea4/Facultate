/*
9
a.elimina_secventa(l1,...,ln) = - [] , daca n=0
			        - [] , daca n=1
				- elimina_secventa(l2,...,ln) daca l2=l1+1
				- [l2,...,ln] altfel
  model de flux: (i,i),(i,o)

  sterg(l1,...,ln) = - lista vida , daca n=0
                     - [l1] daca , daca n=1
                     - sterg(elimina_secventa([l1,l2,...,ln]) , daca
		     l2=l1+1
		     - l1 (+) sterg(l2,...,ln) , altfel
*/

%sterge_secventa(L:lista,R:lista)
%model de flux: (i,o),(i,i)
sterge_secventa([],[]):-!.
sterge_secventa([_],[]):-!.
sterge_secventa([X,Y|T],Rest):-
	Y=:=X+1,!,
	sterge_secventa([Y|T],Rest2),
	Rest=Rest2.
sterge_secventa([X,Y|T],[Y|T]):-
	Y=\=X+1.

%sterg(L:lista,R:lista)
%model de flux: (i,o),(i,i)
sterg([],[]):-!.

sterg([X],[X]):-!.

sterg([X,Y|T],L):-
	Y=:=X+1,!,
	sterge_secventa([X,Y|T],Rest),
	sterg(Rest,L).

sterg([X,Y|T],[X|L]):-
      Y=\=X+1,
      sterg([Y|T],L).

