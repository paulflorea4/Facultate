    69                                          
    70                                          ;(a+b*c+2/c)/(2+a)+e->ecx:ebx
    71 0000005C 01C3                            add ebx,eax
    72 0000005E 11D1                            adc ecx,edx
    73                                          
    74                                          ;x->edx:eax
    75 00000060 A1[08000000]                    mov eax,[x]
    76 00000065 8B15[0C000000]                  mov edx,[x+4]
    77                                          
    78                                          ;(a+b*c+2/c)/(2+a)+e+x->ecx:ebx
    79 0000006B 01C3                            add ebx,eax
    80 0000006D 11D1                            adc ecx,edx
    81                                          ; exit(0)
    82 0000006F 6A00                            push    dword 0      ; push the parameter for exit onto the stack
    83 00000071 FF15[00000000]                  call    [exit]       ; call exit to terminate the program
