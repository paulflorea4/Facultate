     1                                  bits 32
     2                                  global start
     3                                  
     4                                  extern factorial
     5                                  
     6                                  extern exit, scanf, printf
     7                                  import exit msvcrt.dll
     8                                  import scanf msvcrt.dll
     9                                  import printf msvcrt.dll
    10                                  
    11                                  segment data use32 class=data
    12 00000000 00000000                    n dd 0
    13 00000004 6E3A2000                    msg db "n: ", 0
    14 00000008 256400                      format db "%d", 0
    15 0000000B 256421203D20256400          format_p db "%d! = %d", 0
    16                                  	
    17                                  ; Scrieți un program care calculează factorialul unui număr natural n citit de la tastatură.
    18                                  segment code use32 class=code
    19                                      ; programul principal
    20                                      start:
    21                                          ; afisez mesaj
    22                                          ; printf(msg)
    23 00000000 68[04000000]                    push dword msg
    24 00000005 FF15[00000000]                  call [printf]
    25 0000000B 83C404                          add esp, 1*4
    26                                          
    27                                          ; citim n
    28                                          ; scanf("%d", &n)
    29 0000000E 68[00000000]                    push dword n
    30 00000013 68[08000000]                    push dword format
    31 00000018 FF15[00000000]                  call [scanf]
    32 0000001E 83C408                          add esp, 4*2
    33                                          
    34                                          ; calculez factorial
    35 00000021 A1[00000000]                    mov eax, [n]        ; transmit argumente
    36 00000026 E8(00000000)                    call factorial
    37                                          
    38                                          ; afisez factorial
    39 0000002B 50                              push dword eax
    40 0000002C FF35[00000000]                  push dword [n]
    41 00000032 68[0B000000]                    push dword format_p
    42 00000037 FF15[00000000]                  call [printf]
    43 0000003D 83C40C                          add esp, 3*4
    44                                      
    45                                          ; exit(0)
    46 00000040 6A00                            push dword 0
    47 00000042 FF15[00000000]                  call [exit]
