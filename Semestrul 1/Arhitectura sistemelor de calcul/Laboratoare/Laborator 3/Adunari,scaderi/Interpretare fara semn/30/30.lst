     1                                  ;a - byte, b - word, c - double word, d - qword
     2                                  ;(b+c+a)-(d+c+a)
     3                                  bits 32 ; assembling for the 32 bits architecture
     4                                  
     5                                  ; declare the EntryPoint (a label defining the very first instruction of the program)
     6                                  global start        
     7                                  
     8                                  ; declare external functions needed by our program
     9                                  extern exit               ; tell nasm that exit exists even if we won't be defining it
    10                                  import exit msvcrt.dll    ; exit is a function that ends the calling process. It is defined in msvcrt.dll
    11                                                            ; msvcrt.dll contains exit, printf and all the other important C-runtime specific functions
    12                                  
    13                                  ; our data is declared here (the variables needed by our program)
    14                                  segment data use32 class=data
    15                                      ; a resb 1
    16                                      ; b resw 1
    17                                      ; c resd 1
    18                                      ; d resq 1
    19                                      
    20 00000000 01                          a db 1h
    21 00000001 0200                        b dw 2h
    22 00000003 03000000                    c dd 3h
    23 00000007 0400000000000000            d dq 4h
    24                                  
    25                                  ; our code starts here
    26                                  segment code use32 class=code
    27                                      start:
    28                                          ;c->edx:eax
    29 00000000 A1[03000000]                    mov eax,[c]
    30 00000005 BA00000000                      mov edx,0
    31                                          
    32                                          ;a->ecx:ebx
    33 0000000A B900000000                      mov ecx,0
    34 0000000F BB00000000                      mov ebx,0
    35 00000014 8A1D[00000000]                  mov bl,[a]
    36                                          
    37                                          ;c+a->edx:eax
    38 0000001A 01D8                            add eax,ebx
    39 0000001C 11CA                            adc edx,ecx
    40                                          
    41                                          ;b->ecx:ebx
    42 0000001E B900000000                      mov ecx,0
    43 00000023 BB00000000                      mov ebx,0
    44 00000028 668B1D[01000000]                mov bx,[b]
    45                                          
    46                                          ;(b+c+a)->ecx:ebx
    47 0000002F 01C3                            add ebx,eax
    48 00000031 11C1                            adc ecx,eax
    49                                          
    50                                          ;Salvez pe stiva (b+c+a)
    51 00000033 53                              push ebx
    52 00000034 51                              push ecx
    53                                          
    54                                          ;d->ecx:ebx
    55 00000035 8B1D[07000000]                  mov ebx,[d]
    56 0000003B 8B0D[0B000000]                  mov ecx,[d+4]
    57                                          
    58                                          ;(d+c+a)->ecx:ebx
    59 00000041 01C3                            add ebx,eax
    60 00000043 11C1                            adc ecx,eax
    61                                          
    62                                          ;(b+c+a)->edx:eax
    63 00000045 5A                              pop edx
    64 00000046 58                              pop eax
    65                                          
    66                                          ;(b+c+a)-(d+c+a)->edx:eax
    67 00000047 29D8                            sub eax,ebx
    68 00000049 19CA                            sbb edx,ecx
    69                                      
    70                                          ; exit(0)
    71 0000004B 6A00                            push    dword 0      ; push the parameter for exit onto the stack
    72 0000004D FF15[00000000]                  call    [exit]       ; call exit to terminate the program
