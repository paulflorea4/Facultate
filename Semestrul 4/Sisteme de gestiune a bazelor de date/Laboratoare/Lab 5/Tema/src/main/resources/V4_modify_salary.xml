<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="4" author="student">

        <modifyDataType
                tableName="employees"
                columnName="salary"
                newDataType="DECIMAL(12,2)"/>

        <rollback>
            <modifyDataType
                    tableName="employees"
                    columnName="salary"
                    newDataType="DECIMAL(10,2)"/>
        </rollback>

    </changeSet>

</databaseChangeLog>