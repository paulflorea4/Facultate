<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="230.0" prefWidth="301.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.laboratorGUI.controller.LoginController">
    <Label layoutX="119.0" layoutY="31.0" text="Login">
        <font>
          <Font name="System Bold" size="24.0"/>
        </font>
    </Label>
    <GridPane layoutX="51.0" layoutY="99.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="95.0" minWidth="10.0" prefWidth="66.0"/>
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="134.0" minWidth="10.0" prefWidth="134.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        </rowConstraints>
        <Label text="Username"/>
        <Label text="Password" GridPane.rowIndex="1"/>
        <TextField fx:id="usernameTxt" GridPane.columnIndex="1"/>
        <PasswordField fx:id="passwordTxt" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>
    <Button fx:id="loginBtn" layoutX="200.0" layoutY="163.0" mnemonicParsing="false" text="Login"/>
</AnchorPane>
