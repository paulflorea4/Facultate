/*
b.sterg_eterogen(l1,...,ln) = - lista vida , daca n=0
                           - sterg(l1)(+)sterg_eterogen(l2,...,ln),daca
			  l1 e lista
			      - l1 (+) sterg_eterogen(l2,...,ln), altfel

			     - sterg_eterogen(L:lista eterogena,R:lista eterogena)
model de flux: (i,o),(i,i)
*/

sterg_eterogen([],[]):-!.
sterg_eterogen([H|T],[H1|T1]):-
	is_list(H),!,
	sterg(H,H1),
	sterg_eterogen(T,T1).
sterg_eterogen([H|T],[H|T1]):-
	H<5,
	sterg_eterogen(T,T1).
sterg_eterogen([H|T],L):-
	H>=5,
	sterg_eterogen(T,L1),
	L=L1.
