    19 00000005 B900000000                      mov ecx,0
    20                                      parcure_sir:
    21 0000000A AC                              lodsb
    22 0000000B 3C00                            cmp al,0
    23 0000000D 7403                            je sfarsit
    24                                          
    25 0000000F 41                              inc ecx
    26                                          
    27 00000010 EBF8                            jmp parcure_sir
