<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="435.0" prefWidth="514.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.laboratorGUI.controller.AdminController">
    <VBox layoutX="17.0" layoutY="18.0" prefHeight="398.0" prefWidth="480.0">
        <TableView fx:id="tableView" prefHeight="210.0" prefWidth="480.0">
            <columns>
                <TableColumn fx:id="tableColumnID" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="tableColumnUsername" prefWidth="75.0" text="Username" />
                <TableColumn fx:id="tableColumnEmail" prefWidth="75.0" text="Email" />
                <TableColumn fx:id="tableColumnType" prefWidth="75.0" text="Type" />
                <TableColumn fx:id="tableColumnFriends" prefWidth="75.0" text="Friends" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
        <HBox prefHeight="30.0" prefWidth="480.0" spacing="70.0">
            <Button fx:id="prevBtn" mnemonicParsing="false" prefWidth="70" text="Previous" />
            <Button fx:id="addUserBtn" mnemonicParsing="false" prefWidth="70" text="Add" />
            <Button fx:id="removeUserBtn" mnemonicParsing="false" prefWidth="70.0" text="Remove" />
            <Button fx:id="nextBtn" mnemonicParsing="false" prefWidth="70" text="Next" />
            <padding>
                <Insets top="5.0" />
            </padding>
        </HBox>
        <HBox prefHeight="21.0" prefWidth="480.0" spacing="377.0">
            <Label text="Comunitati:">
                <padding>
                    <Insets top="10.0" />
                </padding>
            </Label>
            <Label text="Events:">
                <padding>
                    <Insets top="10.0" />
                </padding>
            </Label>
        </HBox>
        <HBox prefHeight="36.0" prefWidth="480.0" spacing="10.0">
            <padding>
                <Insets top="5.0" />
            </padding>
            <Button fx:id="calcCommunitiesBtn" mnemonicParsing="false" text="Show" />
            <Label fx:id="communitiesLbl" prefHeight="25.0" prefWidth="140.0" text="Numar de comunitati:" />
         <Button fx:id="showEventsBtn" mnemonicParsing="false" text="Show">
            <HBox.margin>
               <Insets left="225.0" />
            </HBox.margin>
         </Button>
        </HBox>
        <HBox prefHeight="36.0" prefWidth="480.0" spacing="10.0">
            <padding>
                <Insets top="5.0" />
            </padding>
            <Button fx:id="showMostSociableCommunityBtn" mnemonicParsing="false" text="Show" />
            <Label prefHeight="26.0" prefWidth="157.0" text="Cea mai sociabila comunitate" />
        </HBox>
        <HBox prefHeight="34.0" prefWidth="480.0" spacing="10.0">
            <padding>
                <Insets top="5.0" />
            </padding>
            <Button fx:id="showDucksBtn" mnemonicParsing="false" text="Show" />
            <Label prefHeight="26.0" prefWidth="42.0" text="Ratuste" />
        </HBox>
    </VBox>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</AnchorPane>
